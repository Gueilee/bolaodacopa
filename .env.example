# ── Turso (https://turso.tech) ─────────────────────────────────────────────
TURSO_DATABASE_URL=libsql://seu-banco.turso.io
TURSO_AUTH_TOKEN=eyJhbGci...

# ── JWT (gere com: openssl rand -base64 32) ──────────────────────────────────
JWT_SECRET=troque-por-uma-string-aleatoria-segura-min-32-chars

# ── API-Football (https://api-sports.io) ─────────────────────────────────────
# REST API  → requer plano Starter (≈$9/mês) para Copa 2026 (season=2026)
# Widgets   → GRATUITOS com qualquer plano, sem consumir req/dia
# Segurança → configure Allowed Domains em dashboard.api-sports.io

# Chave no servidor (cron, sync automático)
API_FOOTBALL_KEY=sua-chave-aqui

# Chave no cliente (widgets embarcáveis — fica visível no HTML)
# ⚠ Configure o domínio autorizado no dashboard antes de usar em produção
NEXT_PUBLIC_API_FOOTBALL_KEY=sua-chave-aqui

# ── WhatsApp (Z-API) — https://app.z-api.io ──────────────────────────────────
# 1. Crie uma instância em app.z-api.io
# 2. Escaneie o QR Code com o WhatsApp da empresa
# 3. Copie o Instance ID e Instance Token abaixo
ZAPI_INSTANCE_ID=sua-instance-id
ZAPI_INSTANCE_TOKEN=seu-instance-token
ZAPI_CLIENT_TOKEN=seu-client-token-opcional   # segurança extra, opcional

# ── Vercel Cron Secret ────────────────────────────────────────────────────────
# Protege a rota /api/cron/sync-fixtures de chamadas externas.
# Gere com: openssl rand -base64 32
# Configure também em: Vercel Dashboard → Settings → Environment Variables
CRON_SECRET=troque-por-string-aleatoria

# ── Seed inicial ──────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@vendemmia.com.br
ADMIN_PASSWORD=Vendemmia@2026
ADMIN_NAME=Administrador

# ── Next.js ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
