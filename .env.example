# =============================================================================
# BOLÃO COPA 2026 — Vendemmia
# Variáveis de ambiente necessárias para produção (Azure App Service)
# Copie este arquivo para .env.local e preencha os valores reais.
# NUNCA commite o .env.local — ele está no .gitignore.
# =============================================================================

# ── Turso (banco de dados) ────────────────────────────────────────────────────
# Acesse: https://turso.tech → seu banco → Connect
TURSO_DATABASE_URL=libsql://bolao-gueilee.aws-us-east-1.turso.io
TURSO_AUTH_TOKEN=SEU_TOKEN_TURSO_AQUI

# ── JWT (sessão de usuários) ──────────────────────────────────────────────────
# Gere com: openssl rand -base64 32
JWT_SECRET=STRING_ALEATORIA_SEGURA_MINIMO_32_CHARS

# ── URL pública do sistema ────────────────────────────────────────────────────
# Azure: https://seuapp.azurewebsites.net  (ou domínio customizado)
NEXT_PUBLIC_BASE_URL=https://seuapp.azurewebsites.net

# ── Server Actions — domínios permitidos (CSRF) ───────────────────────────────
# Liste os domínios separados por vírgula (sem https://, sem barra no final)
# Exemplo: bolaodacopa.azurewebsites.net,bolaodacopa.vendemmia.com.br
# Se vazio, Next.js aceita automaticamente o host da requisição (mais seguro em Azure)
ALLOWED_ORIGINS=

# ── Vercel Blob (upload de imagens/vídeos no Mural Social) ───────────────────
# Funciona em qualquer host (não é exclusivo do Vercel).
# Acesse: https://vercel.com/storage/blob → seu blob store → .env.local
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_SEU_TOKEN_AQUI

# ── Resend (envio de e-mails de convite) ─────────────────────────────────────
# Crie conta gratuita em: https://resend.com (3.000 e-mails/mês grátis)
# Dashboard → API Keys → Create API Key
RESEND_API_KEY=re_SEU_TOKEN_AQUI

# Remetente: use "onboarding@resend.dev" para testes sem domínio verificado,
# ou "bolao@vendemmia.com.br" após verificar o domínio em resend.com/domains
EMAIL_FROM=Bolão Copa 2026 <onboarding@resend.dev>

# ── API-Football (resultados automáticos via cron) ───────────────────────────
# https://api-sports.io — plano Free funciona para widgets; REST requer Starter
API_FOOTBALL_KEY=SUA_CHAVE_API_FOOTBALL
NEXT_PUBLIC_API_FOOTBALL_KEY=SUA_CHAVE_API_FOOTBALL

# ── Cron Secret (protege os endpoints /api/cron/*) ────────────────────────────
# Gere com: openssl rand -base64 32
# No Azure, configure Azure Logic Apps ou Timer para chamar os endpoints com:
#   Header: Authorization: Bearer SEU_CRON_SECRET
#   GET /api/cron/sync-fixtures   → 1x/dia (ex: 10h BRT = 13h UTC)
#   GET /api/cron/daily-reminders → 1x/dia (ex: 09h BRT = 12h UTC)
CRON_SECRET=STRING_ALEATORIA_PARA_PROTEGER_CRON

# ── Admin inicial (usado somente no seed) ────────────────────────────────────
ADMIN_EMAIL=admin@vendemmia.com.br
ADMIN_PASSWORD=Vendemmia@2026
ADMIN_NAME=Administrador

# ── Node.js ──────────────────────────────────────────────────────────────────
NODE_ENV=production
# PORT é definido automaticamente pelo Azure App Service — não precisa setar aqui
